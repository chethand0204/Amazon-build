pipeline 
{
  agent any
  
  stages{
   
    stage('clone project') {
     steps {
          git branch:'main', url:'https://github.com/PraveenKuberABC/Amazon-Jenkins'
      }
    }
 
   stage('clean') {
    steps {
      sh 'mvn clean'
    }
   }

   stage('complie') {
    steps {
      sh 'mvn compile'
    }
   }

   stage('test') {
    steps {
      sh 'mvn test'
    }
   }

   stage('build and install') {
    steps {
      sh 'mvn clean install'
    }
   }

  }

}
